{{ define "email.warning.html" }}
<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .header { background-color: #ffc107; color: #000; padding: 15px; border-radius: 5px; }
        .alert { background-color: #fff3cd; border: 1px solid #ffeaa7; padding: 10px; margin: 10px 0; border-radius: 3px; }
        .label { font-weight: bold; color: #856404; }
        .value { color: #333; }
        .footer { margin-top: 20px; font-size: 12px; color: #666; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 8px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background-color: #ffc107; color: #000; }
    </style>
</head>
<body>
    <div class="header">
        <h2>⚠️ WARNING - ShareToken Blockchain</h2>
        <p>{{ .Alerts | len }} warning(s) detected</p>
    </div>

    {{ range .Alerts }}
    <div class="alert">
        <h3>{{ .Labels.alertname }}</h3>
        <table>
            <tr><td class="label">Severity:</td><td class="value">{{ .Labels.severity }}</td></tr>
            <tr><td class="label">Instance:</td><td class="value">{{ .Labels.instance }}</td></tr>
            <tr><td class="label">Status:</td><td class="value">{{ .Status }}</td></tr>
            <tr><td class="label">Started:</td><td class="value">{{ .StartsAt.Format "2006-01-02 15:04:05 UTC" }}</td></tr>
            {{ if .EndsAt }}
            <tr><td class="label">Ended:</td><td class="value">{{ .EndsAt.Format "2006-01-02 15:04:05 UTC" }}</td></tr>
            {{ end }}
        </table>
        <p><strong>Summary:</strong> {{ .Annotations.summary }}</p>
        <p><strong>Description:</strong> {{ .Annotations.description }}</p>
    </div>
    {{ end }}

    <div class="footer">
        <p>Sent by ShareToken AlertManager</p>
        <p>Group Labels: {{ range .GroupLabels.SortedPairs }}{{ .Name }}={{ .Value }} {{ end }}</p>
    </div>
</body>
</html>
{{ end }}

{{ define "email.warning.text" }}
WARNING - ShareToken Blockchain
================================

