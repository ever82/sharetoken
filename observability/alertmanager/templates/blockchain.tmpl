{{ define "email.blockchain.html" }}
<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .header { background-color: #6f42c1; color: white; padding: 15px; border-radius: 5px; }
        .alert { background-color: #e2d9f3; border: 1px solid #d4c4ed; padding: 10px; margin: 10px 0; border-radius: 3px; }
        .label { font-weight: bold; color: #4a2c7a; }
        .value { color: #333; }
        .footer { margin-top: 20px; font-size: 12px; color: #666; }
        .metric { font-family: monospace; background-color: #f8f9fa; padding: 2px 5px; border-radius: 3px; }
    </style>
</head>
<body>
    <div class="header">
        <h2>🔗 BLOCKCHAIN ALERT - ShareToken</h2>
        <p>{{ .Alerts | len }} blockchain alert(s)</p>
    </div>

    {{ range .Alerts }}
    <div class="alert">
        <h3>{{ .Labels.alertname }}</h3>
        <p><span class="label">Severity:</span> <span class="metric">{{ .Labels.severity }}</span></p>
        <p><span class="label">Instance:</span> <span class="metric">{{ .Labels.instance }}</span></p>
        <p><strong>{{ .Annotations.summary }}</strong></p>
        <p>{{ .Annotations.description }}</p>
    </div>
    {{ end }}

    <div class="footer">
        <p>Sent by ShareToken Blockchain Operations</p>
    </div>
</body>
</html>
{{ end }}

{{ define "slack.blockchain.text" }}
*Blockchain Alert - ShareToken*
{{ range .Alerts }}
*{{ .Labels.alertname }}* - {{ .Labels.severity }}
{{ .Annotations.summary }}
{{ .Annotations.description }}
{{ end }}
{{ end }}
