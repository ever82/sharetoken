{{ define "email.system.html" }}
<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: Arial, sans-serif; margin: 20px; }
        .header { background-color: #17a2b8; color: white; padding: 15px; border-radius: 5px; }
        .alert { background-color: #d1ecf1; border: 1px solid #bee5eb; padding: 10px; margin: 10px 0; border-radius: 3px; }
        .label { font-weight: bold; color: #0c5460; }
        .value { color: #333; }
        .footer { margin-top: 20px; font-size: 12px; color: #666; }
        table { width: 100%; border-collapse: collapse; }
        th, td { padding: 8px; text-align: left; border-bottom: 1px solid #ddd; }
        th { background-color: #17a2b8; color: white; }
    </style>
</head>
<body>
    <div class="header">
        <h2>🖥️ SYSTEM ALERT - ShareToken Infrastructure</h2>
        <p>{{ .Alerts | len }} system alert(s)</p>
    </div>

    {{ range .Alerts }}
    <div class="alert">
        <h3>{{ .Labels.alertname }}</h3>
        <table>
            <tr><td class="label">Severity:</td><td class="value">{{ .Labels.severity }}</td></tr>
            <tr><td class="label">Instance:</td><td class="value">{{ .Labels.instance }}</td></tr>
            <tr><td class="label">Node:</td><td class="value">{{ .Labels.node }}</td></tr>
            <tr><td class="label">Status:</td><td class="value">{{ .Status }}</td></tr>
        </table>
        <p><strong>Summary:</strong> {{ .Annotations.summary }}</p>
        <p><strong>Description:</strong> {{ .Annotations.description }}</p>
    </div>
    {{ end }}

    <div class="footer">
        <p>Sent by ShareToken System Operations</p>
    </div>
</body>
</html>
{{ end }}

{{ define "email.system.text" }}
SYSTEM ALERT - ShareToken Infrastructure
=========================================

{{ .Alerts | len }} system alert(s)

{{ range .Alerts }}
Alert: {{ .Labels.alertname }}
Severity: {{ .Labels.severity }}
Instance: {{ .Labels.instance }}
Node: {{ .Labels.node }}
Status: {{ .Status }}

Summary: {{ .Annotations.summary }}
Description: {{ .Annotations.description }}

---
{{ end }}

Sent by ShareToken System Operations
{{ end }}
